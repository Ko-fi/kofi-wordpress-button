{
	"name": "kofi-wordpress-button",
	"version": "1.3.10",
	"description": "Make it simple for your readers to show their support by adding a \"Buy Me a Coffee\" or \"Support Me on Ko-fi\" button on your WordPress site.",
	"author": "Ko-fi",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build --webpack-copy-php --blocks-manifest --output-path=blocks --source-path=block-src",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start": "wp-scripts start --webpack-copy-php --blocks-manifest  --output-path=blocks --source-path=block-src"
	},
	"dependencies": {
		"@wordpress/block-editor": "latest",
		"@wordpress/blocks": "latest",
		"@wordpress/i18n": "latest"
	},
	"devDependencies": {
		"@wordpress/scripts": "^31.2.0"
	}
}
